{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "make-account-item-demo",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-15",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		// 推論は flash だと MALFORMED_FUNCTION_CALL が多発(~13%/試行)するため pro。抽出は flash。
		"INFER_MODEL": "gemini-2.5-pro",
		"EXTRACT_MODEL": "gemini-2.5-flash",
		"EMBEDDING_MODEL": "gemini-embedding-001"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "make-account-item-demo-index",
			// Vectorize はローカル開発非対応のため remote binding。
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "accounting_demo_db",
			// 自分の D1 を作成して id を入れる: `wrangler d1 create accounting_demo_db`
			"database_id": "b3575054-bf3d-4d5f-898e-ecb46804a980",
			"remote": true
		}
	]
}
